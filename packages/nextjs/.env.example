# Template for NextJS environment variables.

# For local development, copy this file, rename it to .env.local, and fill in the values.
# When deploying live, you'll need to store the vars in Vercel/System config.

# --- Frontend (NEXT_PUBLIC_*) ---
NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
# Where the Vercel-hosted /api/zeitgeist lives. Leave blank when frontend and
# backend share the same domain. Set this for the IPFS build so the static
# site can call the Vercel API:
NEXT_PUBLIC_API_URL=https://your-vercel-deployment.vercel.app
# Used by getMetadata.ts for OG image absolute URLs:
NEXT_PUBLIC_PRODUCTION_URL=https://your-domain.example

# --- Backend (Vercel only — NOT bundled into the static site) ---
ALCHEMY_API_KEY=
BRAVE_SEARCH_API_KEY=
OPENAI_API_KEY=
# Vercel KV (Redis) — `vercel kv create`
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
